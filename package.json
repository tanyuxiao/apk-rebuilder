{
  "name": "apk-rebuilder",
  "version": "2.0.0",
  "description": "APK Rebuilder backend service implemented with Node.js, Express, and TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "dev:server": "APK_REBUILDER_MODE=dev ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:ui": "vite --config vite.config.mjs",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "lint": "npm run type-check",
    "type-check": "tsc --noEmit",
    "self-check": "node scripts/self-check.js",
    "bootstrap-tools": "bash scripts/bootstrap-tools.sh",
    "test:docker": "docker compose run --rm --no-deps apk-rebuilder node scripts/self-check.js",
    "test": "npm run self-check"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bullmq": "^5.70.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.0",
    "ioredis": "^5.10.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "concurrently": "^9.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.1.0"
  }
}
