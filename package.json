{
  "name": "apk-modder",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules .pnpm-store",
    "docker:build": "docker build -t apk-modder:dev .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:save": "mkdir -p builds && docker save apk-modder:dev -o builds/apk-modder-image.tar",
    "docker:load": "docker load -i builds/apk-modder-image.tar",
    "release:docker": "pnpm run docker:build && pnpm run docker:save"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "execa": "^9.6.0",
    "express": "^4.21.2",
    "fs-extra": "^11.3.0",
    "multer": "^1.4.5-lts.2",
    "pino": "^10.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.14",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "supertest": "^7.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2",
    "vitest": "^2.1.4"
  }
}
